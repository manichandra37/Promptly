{
  "manifest_version": 3,
  "name": "promptly",
  "version": "1.0.0",
  "description": "Token counter and Optimizer for LLM prompts",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://perplexity.ai/*",
        "https://grok.com/*"
      ],
      "css": ["content/content.css"],
      "js": ["content/content.js"]
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": ["storage", "activeTab"],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
